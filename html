<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WeatherLens 2026</title>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <style>
        :root { --primary: #4ade80; --bg-dark: #0f172a; --sidebar: #1a1a1a; --glass: rgba(255, 255, 255, 0.05); }
        body, html { margin: 0; padding: 0; font-family: 'Segoe UI', sans-serif; background: var(--bg-dark); color: white; height: 100vh; overflow: hidden; }
        
        .login-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: radial-gradient(circle, #1e293b, #0f172a); display: flex; justify-content: center; align-items: center; z-index: 9999; }
        .login-box { background: var(--glass); padding: 40px; border-radius: 24px; text-align: center; border: 1px solid rgba(255,255,255,0.1); backdrop-filter: blur(20px); width: 320px; }
        
        .app-container { display: none; height: 100vh; width: 100%; }
        nav { width: 260px; background: var(--sidebar); padding: 20px; border-right: 1px solid #333; display: flex; flex-direction: column; }
        nav h2 { color: var(--primary); margin-bottom: 30px; }
        nav li { padding: 12px; margin: 8px 0; cursor: pointer; border-radius: 8px; color: #94a3b8; list-style: none; transition: 0.2s; }
        nav li.active { background: #2d2d2d; color: var(--primary); font-weight: bold; border-left: 4px solid var(--primary); }
        
        main { flex: 1; padding: 40px; overflow-y: auto; background: linear-gradient(to bottom, #0f172a, #161e2e); }
        
        .weather-card { background: var(--glass); padding: 30px; border-radius: 24px; border: 1px solid rgba(255,255,255,0.1); max-width: 850px; margin-bottom: 20px; }
        .grid-info { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 15px; margin-top: 25px; }
        .info-box { background: rgba(0,0,0,0.3); padding: 20px; border-radius: 16px; border: 1px solid rgba(255,255,255,0.05); }
        
        #map { height: 350px; border-radius: 20px; margin-top: 20px; width: 100%; border: 1px solid #334155; }
        input { background: #1e293b; border: 1px solid #334155; color: white; padding: 14px; border-radius: 12px; width: 250px; outline: none; }
        button { background: var(--primary); color: #064e3b; padding: 14px 24px; border: none; border-radius: 12px; font-weight: bold; cursor: pointer; transition: 0.3s; }
        button:hover { opacity: 0.9; transform: translateY(-1px); }
        
        .view-section { display: none; }
        .view-section.active { display: block; animation: fadeIn 0.4s ease; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        
        .news-item { border-left: 4px solid var(--primary); padding: 15px; margin-bottom: 12px; background: rgba(255,255,255,0.03); border-radius: 0 10px 10px 0; }
        
        .about-content h3 { color: var(--primary); margin-top: 25px; }
        .about-content ul { list-style: none; padding: 0; }
        .about-content li { margin-bottom: 10px; padding-left: 20px; position: relative; }
        .about-content li::before { content: "✔"; position: absolute; left: 0; color: var(--primary); }

        .lang-toggle { display: flex; background: #1e293b; border-radius: 10px; overflow: hidden; border: 1px solid #334155; }
        .lang-toggle button { border-radius: 0; padding: 8px 15px; font-size: 0.85rem; background: transparent; color: white; }
        .lang-toggle button.active { background: var(--primary); color: #064e3b; }
    </style>
</head>
<body>
    <div id="loginPage" class="login-overlay">
        <div class="login-box">
            <h1 style="color: var(--primary);">WeatherLens</h1>
            <input type="text" id="username" placeholder="Username" style="width: 85%; margin-bottom: 15px;">
            <input type="password" id="password" placeholder="Password" style="width: 85%; margin-bottom: 15px;">
            <p style="color: #94a3b8; font-size: 0.85rem; margin-bottom: 20px;">Hint: Use <b>admin</b> & password <b>1234</b></p>
            <button onclick="handleLogin()" style="width: 95%;">LOGIN</button>
        </div>
    </div>

    <div class="app-container">
        <nav>
            <h2>WeatherLens</h2>
            <ul>
                <li class="active" onclick="showSection('dashboard', this)">🌍 Dashboard</li>
                <li onclick="showSection('about', this)">ℹ️ About This App</li>
                <li onclick="showSection('insight-hub', this)">📊 Crop Insight Hub</li>
                <li onclick="showSection('crop-info', this)">🌱 Crop Info</li>
                <li onclick="showSection('disaster', this)">⚠️ Disaster Timeline</li>
            </ul>
        </nav>
        <main>
            <div id="dashboard" class="view-section active">
                <input type="text" id="cityInput" placeholder="Enter City Name...">
                <button onclick="getWeather()">Fetch Weather Data</button>
                <div class="weather-card" style="margin-top:20px;">
                    <h1 id="cityName">--</h1>
                    <p id="date">--</p>
                    <h2 id="temp" style="font-size: 4rem; color: var(--primary);">--°C</h2>
                    <div class="grid-info">
                        <div class="info-box"><h3>💧 Humidity</h3><span id="humidity">--</span>%</div>
                        <div class="info-box"><h3>🌬️ Wind</h3><span id="wind">--</span> m/s</div>
                        <div class="info-box"><h3>⚠️ Agri-Risk</h3><span id="risk">--</span></div>
                        <div class="info-box"><h3>🌱 Suggestion</h3><span id="crop">--</span></div>
                    </div>
                </div>
                <div id="map"></div>
            </div>

            <div id="about" class="view-section">
                <div class="weather-card about-content">
                    <h1>🌦️ About WeatherLens</h1>
                    <p>WeatherLens is not just another weather app—it’s your intelligent companion for understanding the environment in a smarter, more meaningful way. Designed with a blend of modern technology and real-world practicality, WeatherLens transforms raw weather data into clear insights that actually help you take action.</p>
                    <p>Instead of simply showing temperature or humidity, WeatherLens analyzes live weather conditions and connects them to real-life outcomes—especially in agriculture. Whether you're a student, a developer, or someone interested in smart farming, this app helps you see beyond the forecast and understand what the weather truly means.</p>
                    
                    <h3>🌱 Why WeatherLens Stands Out</h3>
                    <ul>
                        <li>Real-time weather insights with accurate data</li>
                        <li>Smart crop recommendations based on conditions</li>
                        <li>Location-based analysis for personalized results</li>
                        <li>Simple, intuitive UI for easy understanding</li>
                        <li>Built for innovation, learning, and real-world impact</li>
                    </ul>

                    <h3>📲 How to Use WeatherLens</h3>
                    <p><b>🔍 Enter a City Name:</b> Type the name of any city you want to analyze.</p>
                    <p><b>🌦️ Fetch Weather Data:</b> Click on the search button to get real-time weather details.</p>
                    <p><b>🌱 View Smart Suggestions:</b> Based on the weather, the app suggests suitable crops.</p>

                    <h3>🚀 Current Version (v1.0)</h3>
                    <ul>
                        <li>Real-time weather data integration using API</li>
                        <li>Dynamic UI with responsive design</li>
                        <li>Smart crop recommendation system</li>
                    </ul>

                    <h3 style="color: #60a5fa;">🔮 Coming Soon</h3>
                    <p>Advanced AI predictions • Map-based visualization • Historical trends</p>
                </div>
            </div>

            <div id="insight-hub" class="view-section">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                    <h1>📊 Crop Insight Hub</h1>
                    <div class="lang-toggle">
                        <button id="lang-en" class="active" onclick="toggleInsightLang('en')">English</button>
                        <button id="lang-hi" onclick="toggleInsightLang('hi')">हिंदी</button>
                    </div>
                </div>
                <div class="weather-card">
                    <p id="hub-intro">Discover the perfect temperature, rainfall, and seasonal requirements for each crop.</p>
                    <div style="display: flex; gap: 10px; margin-top: 15px;">
                        <input type="text" id="insightSearch" placeholder="Search (Wheat, Cotton, Mango...)" style="flex: 1;">
                        <button onclick="searchCropInsight()">Analyze</button>
                        <button id="clearBtn" onclick="clearInsight()" style="background: rgba(255,255,255,0.1); color: #94a3b8; border: 1px solid #334155; width: auto;">Clear Search</button>
                    </div>
                    <div id="insightResult" style="display: none; margin-top: 25px;">
                        <div class="info-box" style="border: 1px solid var(--primary); background: rgba(74, 222, 128, 0.05); padding: 25px;">
                            <h2 id="resTitle" style="color: var(--primary); margin-top: 0;"></h2>
                            <p id="resDesc" style="line-height: 1.6; color: #cbd5e1;"></p>
                            <div class="grid-info">
                                <div class="info-box" style="background: rgba(0,0,0,0.2);">
                                    <h3 id="lbl-temp">🌡️ Ideal Temp</h3>
                                    <span id="resTemp"></span>
                                </div>
                                <div class="info-box" style="background: rgba(0,0,0,0.2);">
                                    <h3 id="lbl-rain">🌧️ Rainfall</h3>
                                    <span id="resRain"></span>
                                </div>
                                <div class="info-box" style="background: rgba(0,0,0,0.2);">
                                    <h3 id="lbl-regions">📍 Best Regions</h3>
                                    <span id="resRegions"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div id="crop-info" class="view-section">
                <h1>🌱 Indian Crop Intelligence</h1>
                <div class="grid-info" id="cropGrid"></div>
            </div>

            <div id="disaster" class="view-section">
                <h1>⚠️ Active Disaster Timeline</h1>
                <div id="disasterList"></div>
            </div>
        </main>
    </div>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="script.js"></script>
</body>
</html>
